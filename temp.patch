+    // 2. Append the rest of the path with stable slash handling
+    const normalizedPath = String(path || '');
+    if (!normalizedPath) {
+        return url;
+    }
+
+    // query-string only path: keep route untouched
+    if (normalizedPath.startsWith('?')) {
+        return `${url}${normalizedPath}`;
+    }
+
+    // enforce exactly one slash between endpoint and appended path segment
+    const baseNoSlash = url.replace(/\/+$/, '');
+    const pathNoSlash = normalizedPath.replace(/^\/+/, '');
+    url = `${baseNoSlash}/${pathNoSlash}`;
 
     // 3. Handle Query Parameters (if you ever need them)
     // (Omitted for brevity, but a complete helper would handle them here)
     
     return url;
 }
 
 function apiFetch(input, init = {}) {
   return fetch(input, withUserHeader(init));
 }
 
 // Export for ES modules
